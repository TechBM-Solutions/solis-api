# Solis API details
SOLIS_AUTH_MODE=auto
SOLIS_BASE_URL=https://www.soliscloud.com:13333
SOLIS_LOGIN_PATH=/v1/api/userLogin
SOLIS_BATTERY_PATH=/v1/api/inverterDetail
SOLIS_USERNAME=your-email@example.com
SOLIS_PASSWORD=your-password
SOLIS_PLANT_ID=your-plant-id
SOLIS_KEY_ID=your-api-key-id
SOLIS_KEY_SECRET=your-api-key-secret

# App behavior
POLL_INTERVAL_SECONDS=300
FULL_BATTERY_PERCENT=100
WEATHER_LATITUDE=
WEATHER_LONGITUDE=
WEATHER_RAIN_THRESHOLD_MM=0.1

# Optional outbound report webhook
REPORT_WEBHOOK_URL=
REPORT_WEBHOOK_TOKEN=

# Optional API auth for external automation clients
API_AUTH_ENABLED=false
API_AUTH_TOKEN=

# API server
HOST=0.0.0.0
PORT=8000
